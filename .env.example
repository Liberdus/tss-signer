# URL of the coordinator server
COORDINATOR_URL=http://127.0.0.1:8000

# Liberdus collector API
COLLECTOR_HOST=http://127.0.0.1:3035

# Liberdus proxy/node
PROXY_SERVER_HOST=http://127.0.0.1:3030

# Auth keypair (alternative to keystores/tss_signer_keypair_party_N.json)
# TSS_SIGNER_PUB_KEY=
# TSS_SIGNER_SEC_KEY=
# TSS_SIGNER_KEYPAIR_FILE=

# Force auth on or off regardless of chain-config.json
# ENABLE_SHARDUS_CRYPTO_AUTH=true
