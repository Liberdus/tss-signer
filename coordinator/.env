# Server configuration
PORT=8000
NODE_ENV=development

# Redis configuration
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
# REDIS_SENTINEL_NAME=mymaster
# REDIS_SENTINEL_URLS=localhost:26379,localhost:26380,localhost:26381

# Authentication
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRATION=1h
API_KEY=your-api-key-for-initial-registration

# Security
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# Session management
SESSION_TTL=3600